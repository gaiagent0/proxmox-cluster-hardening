# =============================================================
# proxmox-cluster-hardening — Environment Variables
# Copy to: configs/env  (never commit configs/env to git)
# =============================================================

# --- Node IP addresses (SERVERS VLAN) ---
PVE01_IP=10.10.40.11
PVE02_IP=10.10.40.12
PVE03_IP=10.10.40.13

# --- Corosync ring IPs (dedicated sync VLAN) ---
PVE01_COROSYNC_IP=10.10.99.11
PVE02_COROSYNC_IP=10.10.99.12
PVE03_COROSYNC_IP=10.10.99.13

# --- NIC names (verify with: ip link show) ---
# Common values: nic0, eth0, eno1, enp3s0
PVE01_NIC=nic0
PVE02_NIC=nic0
PVE03_NIC=nic0

# --- Cluster name (as created with pvecm create) ---
CLUSTER_NAME=homelab-cluster

# --- SSH options (adjust StrictHostKeyChecking for production) ---
SSH_OPTS="-o StrictHostKeyChecking=no -o ConnectTimeout=5 -o LogLevel=ERROR"

# --- Reboot wait times (seconds) ---
POST_REBOOT_WAIT=20         # after issuing reboot command
NODE_WAIT_TIMEOUT=240       # max seconds to wait for SSH to come back
COROSYNC_SYNC_WAIT=30       # after SSH returns, wait for corosync sync

# --- LXC IDs to verify in boot-check (space-separated per node) ---
PVE01_CT_IDS="101 105 106 107 203"
PVE02_CT_IDS="201 204 208"
PVE03_CT_IDS="302 303"

# --- PBS write-test (CT ID and path inside CT) ---
PBS_NODE_IP=${PVE02_IP}
PBS_CT_ID=201
PBS_TEST_PATH="/var/lib/proxmox-backup/backups/.boot-test"
